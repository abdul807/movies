# Auto detect text files and perform LF normalization
* text=auto

# Source code files - always use LF
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf

# Configuration files
*.config.js text eol=lf
*.config.ts text eol=lf
*.json text eol=lf
.env* text eol=lf
.gitignore text eol=lf

# Binary files - should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary